<controls:MetroWindow x:Class="StartLauncher.App.Views.MainWindow"
                      x:Name="Root"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                      xmlns:controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
                      xmlns:viewModels="clr-namespace:StartLauncher.App.ViewModels"
                      mc:Ignorable="d"
                      Title="Start Launcher" Height="520" Width="760"
                      MinHeight="360" MinWidth="560"
                      ShowInTaskbar="True"
                      Visibility="Visible"
                      Icon="../Resources/Bokehlicia-Captiva-Rocket.ico"
                      BorderBrush="{DynamicResource MahApps.Brushes.Accent}"
                      BorderThickness="1"
                      WindowStartupLocation="CenterScreen"
                      d:DataContext="{d:DesignInstance viewModels:MainViewModel}">

    <controls:MetroWindow.RightWindowCommands>
        <controls:WindowCommands>
            <Button x:Name="ThemeToggleButton" Click="ThemeToggleButton_OnClick" ToolTip="Toggle light/dark theme">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="ThemeToggleIcon" FontFamily="Segoe MDL2 Assets" Text="&#xE708;" FontSize="15" />
                </StackPanel>
            </Button>
        </controls:WindowCommands>
    </controls:MetroWindow.RightWindowCommands>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Search -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SearchBox"
                     controls:TextBoxHelper.Watermark="Search commands..."
                     controls:TextBoxHelper.ClearTextButton="True"
                     controls:TextBoxHelper.SelectAllOnFocus="True"
                     TextChanged="SearchBox_OnTextChanged"
                     VerticalContentAlignment="Center"
                     Height="32" />
        </Grid>

        <!-- Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="110" />
            </Grid.ColumnDefinitions>

            <DataGrid x:Name="CommandsListView"
                      Grid.Column="0" Margin="0,0,8,0"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      IsTextSearchCaseSensitive="False"
                      IsTextSearchEnabled="True"
                      TextSearch.TextPath="Name"
                      AlternatingRowBackground="{DynamicResource MahApps.Brushes.Gray10}"
                      RowHeight="30"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="{DynamicResource MahApps.Brushes.Gray8}"
                      HeadersVisibility="Column"
                      CanUserAddRows="False"
                      CanUserResizeRows="False"
                      SelectionMode="Single"
                      ItemsSource="{Binding Commands}"
                      SelectedItem="{Binding SelectedCommand}">
                <DataGrid.InputBindings>
                    <MouseBinding
                        MouseAction="LeftDoubleClick"
                        Command="{Binding EditCommand}"
                        CommandParameter="{Binding ElementName=Root}" />
                    <KeyBinding Key="Delete"
                                Command="{Binding RemoveCommand}"
                                CommandParameter="{Binding ElementName=Root}" />
                    <KeyBinding Key="Return"
                                Command="{Binding EditCommand}"
                                CommandParameter="{Binding ElementName=Root}" />
                </DataGrid.InputBindings>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Command" Binding="{Binding Name}" SortDirection="Ascending" Width="180" />
                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>

            <!-- Empty state -->
            <TextBlock Grid.Column="0" Margin="0,0,8,0"
                       Text="No commands yet. Click &quot;Add&quot; to create your first one."
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       TextWrapping="Wrap" TextAlignment="Center" MaxWidth="260"
                       Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                       Visibility="{Binding Commands.Count, Converter={StaticResource ZeroToVisibleConverter}, FallbackValue=Collapsed}" />

            <StackPanel Grid.Column="1" Orientation="Vertical">
                <Button Command="{Binding AddCommand, Mode=OneWay}"
                        CommandParameter="{Binding ElementName=Root}"
                        Style="{StaticResource MahApps.Styles.Button.Square.Accent}"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,6" Padding="0,6">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE710;" Margin="0,0,6,0" />
                        <TextBlock Text="_Add..." />
                    </StackPanel>
                </Button>

                <Button Command="{Binding EditCommand, Mode=OneWay}"
                        CommandParameter="{Binding ElementName=Root}"
                        Style="{StaticResource MahApps.Styles.Button.Square}"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,6" Padding="0,6">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE70F;" Margin="0,0,6,0" />
                        <TextBlock Text="_Edit..." />
                    </StackPanel>
                </Button>

                <Button Command="{Binding RemoveCommand, Mode=OneWay}"
                        CommandParameter="{Binding ElementName=Root}"
                        Style="{StaticResource MahApps.Styles.Button.Square}"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,6" Padding="0,6">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE74D;" Margin="0,0,6,0" />
                        <TextBlock Text="_Remove" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Status bar -->
        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="{Binding Commands.Count, StringFormat={}{0} command(s)}"
                       Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                       VerticalAlignment="Center" FontSize="11" />
            <TextBlock Grid.Column="1"
                       Text="Double-click or Enter to edit &#183; Delete to remove"
                       Foreground="{DynamicResource MahApps.Brushes.Gray3}"
                       VerticalAlignment="Center" FontSize="11" />
        </Grid>
    </Grid>
</controls:MetroWindow>
