<controls:MetroWindow x:Class="StartLauncher.App.Views.EditWindow"
                      x:Name="Window"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                      xmlns:controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
                      xmlns:viewModels="clr-namespace:StartLauncher.App.ViewModels"
                      mc:Ignorable="d"
                      Title="Edit Command" Height="440" Width="460"
                      MinHeight="400" MinWidth="400"
                      Icon="../Resources/Bokehlicia-Captiva-Rocket.ico"
                      BorderBrush="{DynamicResource MahApps.Brushes.Accent}"
                      BorderThickness="1"
                      WindowStartupLocation="CenterOwner"
                      d:DataContext="{d:DesignInstance viewModels:EditViewModel}"
                      FocusManager.FocusedElement="{Binding ElementName=NameTextBox}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Name" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBox x:Name="NameTextBox" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                     controls:TextBoxHelper.Watermark="unique name"
                     Height="30" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Description" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                     controls:TextBoxHelper.Watermark="additional description"
                     Height="30" />
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,10" MinHeight="90">
            <TextBlock Text="Command" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBox Text="{Binding Command, UpdateSourceTrigger=PropertyChanged}"
                     controls:TextBoxHelper.Watermark="what to execute"
                     FontFamily="Consolas"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     MinHeight="90" />
        </StackPanel>

        <CheckBox Grid.Row="3"
                  IsChecked="{Binding RunAsAdmin, UpdateSourceTrigger=PropertyChanged}"
                  Content="Run as Administrator"
                  Margin="0,0,0,4" />

        <Separator Grid.Row="4" Margin="0,8,0,10" />

        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Command="{Binding TestCommand}"
                    Content="_Test"
                    Width="80" />

            <Button Grid.Column="2"
                    Command="{Binding CancelCommand}"
                    CommandParameter="{Binding ElementName=Window}"
                    Content="_Cancel"
                    Width="80" Margin="0,0,8,0"
                    IsCancel="True" />

            <Button Grid.Column="3"
                    Command="{Binding SaveCommand}"
                    CommandParameter="{Binding ElementName=Window}"
                    Style="{StaticResource MahApps.Styles.Button.Square.Accent}"
                    Content="_Save"
                    Width="80"
                    IsDefault="True" />
        </Grid>
    </Grid>
</controls:MetroWindow>
